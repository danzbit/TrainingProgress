# Environment Variables for Local Development
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git!

# GROQ API Key for AI Chat Service
# Get your key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here_replace_with_actual_key

# SQL Server SA password for Docker compose
# Must satisfy SQL Server password complexity requirements.
SQLSERVER_SA_PASSWORD=Your_strong_password_123!

# Optional: Other configuration
# NODE_ENV=development
# DEBUG=true
